---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import voicesData from '../../../data/top_voices.json';

const title = 'Top 25 B2B Data Stack Voices 2026';
const description = 'Data-driven rankings of the 25 most influential voices shaping how B2B teams choose and implement their data tools. Updated for 2026.';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Top Voices' }
];

const allSchemas: object[] = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.label,
      ...(item.href ? { "item": `https://datastackguide.com${item.href}` } : {})
    }))
  },
  {
    "@type": "ItemList",
    "name": voicesData.title,
    "numberOfItems": voicesData.voices.length,
    "itemListElement": voicesData.voices.map((v: any) => ({
      "@type": "ListItem",
      "position": v.rank,
      "item": {
        "@type": "Person",
        "name": v.name,
        "jobTitle": v.title,
        "worksFor": { "@type": "Organization", "name": v.company },
        "url": v.linkedin_url
      }
    }))
  },
  {
    "@type": "Article",
    "headline": voicesData.title,
    "author": { "@type": "Person", "name": "Rome Thorndike" },
    "publisher": { "@type": "Organization", "name": "DataStackGuide" },
    "datePublished": "2026-04-14",
    "dateModified": voicesData.last_updated,
    "url": "https://datastackguide.com/voices/"
  }
];

const leaders = voicesData.voices.filter((v: any) => v.tier === 'leader');
const rising = voicesData.voices.filter((v: any) => v.tier === 'rising');
---

<BaseLayout title={title} description={description} canonicalPath="/voices/" schemas={allSchemas}>
  <div class="container" style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem;">
    <Breadcrumbs items={breadcrumbItems} />

    <div style="text-align: center; margin-bottom: 2rem;">
      <span class="text-primary" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;">2026 Rankings</span>
      <h1 style="margin: 0.5rem 0;">{voicesData.title}</h1>
      <p class="text-secondary" style="font-size: 1.1rem;">{voicesData.subtitle}</p>
      <p class="text-muted" style="font-size: 0.85rem;">Last updated: {voicesData.last_updated} &middot; {voicesData.voices.length} voices ranked</p>
    </div>

    <details style="margin-bottom: 2rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-bg-card);">
      <summary style="padding: 1rem 1.25rem; cursor: pointer; font-weight: 600;">How We Ranked These Voices</summary>
      <div style="padding: 0 1.25rem 1.25rem; font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.7;">
        <p>{voicesData.methodology}</p>
        <ul style="padding-left: 1.25rem; margin: 0.75rem 0;">
          <li><strong>Industry impact</strong> (30%): Built tools, created categories, or defined frameworks the industry uses.</li>
          <li><strong>Content reach</strong> (25%): Newsletter subscribers, LinkedIn following, conference keynotes.</li>
          <li><strong>Practitioner relevance</strong> (25%): Content helps B2B teams make better tool decisions.</li>
          <li><strong>Originality</strong> (20%): Original data, frameworks, and contrarian insights.</li>
        </ul>
      </div>
    </details>

    <div style="display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: 2rem; padding: 0.75rem; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 12px;">
      {voicesData.voices.map((v: any) => (
        <a href={`#voice-${v.rank}`} style="font-size: 0.75rem; font-family: monospace; padding: 0.25rem 0.5rem; border-radius: 6px; color: var(--color-text-muted); text-decoration: none;">#{v.rank} {v.name.split(' ')[0]}</a>
      ))}
    </div>

    <h2 style="font-size: 1.3rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--color-primary); margin-bottom: 0.5rem;">Top 10 Leaders</h2>
    <p class="text-secondary" style="margin-bottom: 1rem;">The most recognized voices shaping B2B data tools and martech.</p>
    <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem;">
      {leaders.map((v: any) => (
        <div id={`voice-${v.rank}`} style="border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-bg-card); padding: 1.25rem;">
          <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
            <div style={`font-family: monospace; font-weight: 700; font-size: ${v.rank <= 3 ? '1.25rem' : '1.1rem'}; min-width: 2.5rem; text-align: center; color: ${v.rank <= 3 ? 'var(--color-primary)' : 'var(--color-text-muted)'};`}>#{v.rank}</div>
            <div style="flex: 1; min-width: 0;">
              <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0 0 0.25rem;"><a href={v.linkedin_url} target="_blank" rel="noopener" style="text-decoration: none;">{v.name}</a></h3>
              <p class="text-secondary" style="font-size: 0.85rem; margin: 0 0 0.5rem;">{v.title} at {v.company}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
                {v.tags.map((t: string) => (
                  <span style="font-size: 0.7rem; font-family: monospace; padding: 0.15rem 0.5rem; border-radius: 999px; background: var(--color-primary-subtle); color: var(--color-primary); font-weight: 500;">{t}</span>
                ))}
              </div>
            </div>
            <a href={v.linkedin_url} target="_blank" rel="noopener" style="flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 6px; color: var(--color-text-muted); text-decoration: none;" aria-label={`View ${v.name} on LinkedIn`}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
          <p class="text-secondary" style="margin: 0.75rem 0 0; font-size: 0.9rem; line-height: 1.7; padding-left: calc(2.5rem + 0.75rem);">{v.bio}</p>
        </div>
      ))}
    </div>

    <h2 style="font-size: 1.3rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--color-primary); margin-bottom: 0.5rem;">Rising Voices (11-25)</h2>
    <p class="text-secondary" style="margin-bottom: 1rem;">Practitioners, founders, and analysts gaining momentum in the B2B data stack conversation.</p>
    <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem;">
      {rising.map((v: any) => (
        <div id={`voice-${v.rank}`} style="border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-bg-card); padding: 1.25rem;">
          <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
            <div style="font-family: monospace; font-weight: 700; font-size: 1.1rem; min-width: 2.5rem; text-align: center; color: var(--color-text-muted);">#{v.rank}</div>
            <div style="flex: 1; min-width: 0;">
              <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0 0 0.25rem;"><a href={v.linkedin_url} target="_blank" rel="noopener" style="text-decoration: none;">{v.name}</a></h3>
              <p class="text-secondary" style="font-size: 0.85rem; margin: 0 0 0.5rem;">{v.title} at {v.company}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
                {v.tags.map((t: string) => (
                  <span style="font-size: 0.7rem; font-family: monospace; padding: 0.15rem 0.5rem; border-radius: 999px; background: var(--color-primary-subtle); color: var(--color-primary); font-weight: 500;">{t}</span>
                ))}
              </div>
            </div>
            <a href={v.linkedin_url} target="_blank" rel="noopener" style="flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 6px; color: var(--color-text-muted); text-decoration: none;" aria-label={`View ${v.name} on LinkedIn`}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
          <p class="text-secondary" style="margin: 0.75rem 0 0; font-size: 0.9rem; line-height: 1.7; padding-left: calc(2.5rem + 0.75rem);">{v.bio}</p>
        </div>
      ))}
    </div>

    <div style="text-align: center; padding: 2rem 0;">
      <h2 style="font-size: 1.3rem; margin-bottom: 0.5rem;">Made the List?</h2>
      <p class="text-secondary">Share it. Tag us on LinkedIn. We will amplify your post.</p>
      <p class="text-secondary">Know someone who should be on next year's list? <a href="mailto:rome@getprovyx.com">Let us know</a>.</p>
    </div>
  </div>
</BaseLayout>
