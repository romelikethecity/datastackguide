---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbSchema } from '../../utils/schema';
import toolsData from '../../../data/tools.json';
import categoriesData from '../../../data/categories.json';

const totalJobs = toolsData.total_jobs_analyzed;
const totalCompanies = toolsData.total_companies;

const title = 'B2B Data Reports';
const description = `Data-driven reports on B2B tool adoption, salaries, and market trends. Based on analysis of ${totalJobs.toLocaleString()}+ job postings.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Reports' }
];

const allSchemas: object[] = [
  {
    "@type": "ItemList",
    "name": "B2B Data Reports",
    "numberOfItems": 5,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Most In-Demand B2B Data Tools (2026)",
        "url": "https://datastackguide.com/reports/most-in-demand-tools/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "B2B Data Tools Salary Report",
        "url": "https://datastackguide.com/reports/salary-report/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "B2B Data Tool Stacks: What's Used Together (2026)",
        "url": "https://datastackguide.com/reports/tool-cooccurrence/"
      },
      {
        "@type": "ListItem",
        "position": 4,
        "name": "B2B Data Tools by Category: Demand and Salary Breakdown (2026)",
        "url": "https://datastackguide.com/reports/category-breakdown/"
      },
      {
        "@type": "ListItem",
        "position": 5,
        "name": "Enterprise vs Mid-Market: B2B Data Tool Adoption (2026)",
        "url": "https://datastackguide.com/reports/enterprise-vs-smb/"
      }
    ]
  },
  buildBreadcrumbSchema(breadcrumbItems)
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="reports/"
  schemas={allSchemas}
>
  <div class="container-narrow">
    <Breadcrumbs items={breadcrumbItems} noSchema />

    <section class="reports-hero">
      <h1>Reports</h1>
      <p class="reports-lead">Data-driven analysis of the B2B data tools market. Based on {totalJobs.toLocaleString()}+ job postings across {totalCompanies.toLocaleString()} companies.</p>
    </section>

    <section class="reports-list">
      <a href="/reports/most-in-demand-tools/" class="report-card card">
        <span class="report-badge mono">REPORT</span>
        <h2>Most In-Demand B2B Data Tools (2026)</h2>
        <p>The top 20 B2B data tools ranked by job posting mentions. See which tools companies are actually investing in.</p>
      </a>

      <a href="/reports/salary-report/" class="report-card card">
        <span class="report-badge mono">REPORT</span>
        <h2>B2B Data Tools Salary Report</h2>
        <p>Compensation data for B2B data tool roles. Salary ranges by tool, function, seniority, and location.</p>
      </a>

      <a href="/reports/tool-cooccurrence/" class="report-card card">
        <span class="report-badge mono">REPORT</span>
        <h2>B2B Data Tool Stacks: What's Used Together (2026)</h2>
        <p>Which tools appear together in job postings? See the most common pairings and stack patterns across {totalJobs.toLocaleString()}+ roles.</p>
      </a>

      <a href="/reports/category-breakdown/" class="report-card card">
        <span class="report-badge mono">REPORT</span>
        <h2>Category Demand and Salary Breakdown</h2>
        <p>How do CRM, enrichment, analytics, and other categories compare on job demand and salary? Data for all {categoriesData.categories.length} categories.</p>
      </a>

      <a href="/reports/enterprise-vs-smb/" class="report-card card">
        <span class="report-badge mono">REPORT</span>
        <h2>Enterprise vs Mid-Market Tool Adoption</h2>
        <p>Enterprise tools pay more but mid-market tools are growing faster. See the salary premium, tool counts, and career implications.</p>
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .reports-hero {
    padding: var(--space-8) 0 var(--space-6);
  }

  .reports-hero h1 {
    margin-bottom: var(--space-3);
  }

  .reports-lead {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    max-width: 600px;
  }

  .reports-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-16);
  }

  .report-card {
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .report-card:hover {
    border-color: var(--color-primary);
  }

  .report-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: var(--color-primary-subtle);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }

  .report-card h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .report-card p {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.5;
  }
</style>
