---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ToolCard from '../components/ToolCard.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';

import categoriesData from '../../data/categories.json';
import marketData from '../../data/market_signals.json';

const categories = categoriesData.categories;
const topTools = marketData.top_tools;
const totalJobs = marketData.total_jobs_analyzed;
const totalCompanies = marketData.total_companies;
const totalTools = marketData.total_tools_tracked;

// Find category color for each tool
function getCategoryColor(catSlug: string): string {
  const cat = categories.find((c: any) => c.slug === catSlug);
  return cat?.color || '#14B8A6';
}

function getCategoryName(catSlug: string): string {
  const cat = categories.find((c: any) => c.slug === catSlug);
  return cat?.name || catSlug;
}

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://datastackguide.com/#organization",
      "name": "DataStackGuide",
      "url": "https://datastackguide.com",
      "logo": "https://datastackguide.com/assets/icons/icon.svg",
      "description": "Compare 200+ B2B data enrichment, validation, and intent tools. Real pricing, honest reviews, job market demand data."
    },
    {
      "@type": "WebSite",
      "@id": "https://datastackguide.com/#website",
      "name": "DataStackGuide",
      "url": "https://datastackguide.com",
      "publisher": { "@id": "https://datastackguide.com/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://datastackguide.com/tools/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
};
---

<BaseLayout
  title="DataStackGuide (2026): B2B Data Tool Reviews with Job Demand Data"
  description="200+ B2B data tool reviews in 2026. Real pricing, honest pros and cons, plus hiring demand from 23,000+ job postings across 1,000+ companies. No pay-to-play."
  canonicalPath=""
  schema={schema}
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Find the Right B2B Data Tool</h1>
      <p class="hero-sub">Compare data enrichment, validation, and intent tools. Real pricing. Honest reviews. Job demand data from {totalJobs.toLocaleString()}+ postings.</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number mono">{totalTools}+</span>
          <span class="stat-label">Tools tracked</span>
        </div>
        <div class="stat">
          <span class="stat-number mono">{totalJobs.toLocaleString()}+</span>
          <span class="stat-label">Jobs analyzed</span>
        </div>
        <div class="stat">
          <span class="stat-number mono">{totalCompanies.toLocaleString()}+</span>
          <span class="stat-label">Companies</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA + Social Proof -->
  <section class="section newsletter-hero-section">
    <div class="container">

      <!-- Newsletter Preview Mockup -->
      <div class="dsg-preview-wrapper">
        <h2 class="dsg-preview-heading">See what lands in your inbox</h2>
        <p class="dsg-preview-subheading">Every Tuesday. Tool demand shifts, pricing changes, and stack intelligence from {totalJobs.toLocaleString()}+ job postings.</p>
        <div class="dsg-preview-window">
          <div class="dsg-preview-toolbar">
            <div class="dsg-preview-dots">
              <span class="dsg-preview-dot dsg-preview-dot--red"></span>
              <span class="dsg-preview-dot dsg-preview-dot--yellow"></span>
              <span class="dsg-preview-dot dsg-preview-dot--green"></span>
            </div>
            <span class="dsg-preview-toolbar-title">Inbox | Data Stack Weekly</span>
          </div>
          <div class="dsg-preview-body">
            <div class="dsg-preview-header">
              <div class="dsg-preview-from">
                <span class="dsg-preview-avatar">DS</span>
                <div>
                  <strong class="dsg-preview-sender">Data Stack Weekly</strong>
                  <span class="dsg-preview-date">Tue, Apr 22, 2026</span>
                </div>
              </div>
            </div>
            <h3 class="dsg-preview-headline">Clay adoption surges 340% YoY. Here's what's replacing it.</h3>

            <div class="dsg-preview-stats">
              <div class="dsg-preview-stat-card">
                <span class="dsg-preview-stat-number">{totalTools}+</span>
                <span class="dsg-preview-stat-label">Tools Tracked</span>
                <span class="dsg-preview-stat-trend dsg-preview-stat-trend--up">+8 this quarter</span>
              </div>
              <div class="dsg-preview-stat-card">
                <span class="dsg-preview-stat-number">{totalJobs.toLocaleString()}</span>
                <span class="dsg-preview-stat-label">Jobs Analyzed</span>
                <span class="dsg-preview-stat-trend dsg-preview-stat-trend--up">+2,140 vs last week</span>
              </div>
            </div>

            <div class="dsg-preview-signals">
              <span class="dsg-preview-signal">{totalCompanies.toLocaleString()} Companies</span>
              <span class="dsg-preview-signal-sep"></span>
              <span class="dsg-preview-signal">Weekly Updates</span>
              <span class="dsg-preview-signal-sep"></span>
              <span class="dsg-preview-signal">Vendor-Neutral</span>
            </div>

            <div class="dsg-preview-section-label">Tool Demand in Job Postings This Week</div>
            <table class="dsg-preview-table">
              <thead>
                <tr><th>Tool</th><th>Share</th><th>Trend</th></tr>
              </thead>
              <tbody>
                <tr><td>Salesforce</td><td><div class="dsg-preview-bar-wrap"><div class="dsg-preview-bar" style="width:100%"></div><span>45%</span></div></td><td class="dsg-preview-trend-flat">--</td></tr>
                <tr><td>HubSpot</td><td><div class="dsg-preview-bar-wrap"><div class="dsg-preview-bar" style="width:62%"></div><span>28%</span></div></td><td class="dsg-preview-trend-up">+3%</td></tr>
                <tr><td>Snowflake</td><td><div class="dsg-preview-bar-wrap"><div class="dsg-preview-bar" style="width:42%"></div><span>19%</span></div></td><td class="dsg-preview-trend-up">+5%</td></tr>
                <tr><td>dbt</td><td><div class="dsg-preview-bar-wrap"><div class="dsg-preview-bar" style="width:33%"></div><span>15%</span></div></td><td class="dsg-preview-trend-up">+7%</td></tr>
                <tr><td>Clay</td><td><div class="dsg-preview-bar-wrap"><div class="dsg-preview-bar dsg-preview-bar--highlight" style="width:27%"></div><span>12%</span></div></td><td class="dsg-preview-trend-up dsg-preview-trend--hot">+340%</td></tr>
              </tbody>
            </table>

            <div class="dsg-preview-section-label">Pricing Shifts Worth Watching</div>
            <p class="dsg-preview-text">Apollo dropped their Basic plan from $49/mo to $39/mo. ZoomInfo quietly raised renewal rates 18% for contracts under $25K. Three enrichment tools launched free tiers this month...</p>

            <div class="dsg-preview-fade"></div>
          </div>
          <div class="dsg-preview-cta-bar">
            <span class="dsg-preview-cta-text">Get the full issue every Tuesday</span>
            <a href="/newsletter/" class="dsg-preview-cta-btn">Subscribe Free</a>
          </div>
        </div>
      </div>

      <NewsletterCTA variant="banner" heading="This data changes every week" subtext="Get the latest tool demand trends, pricing shifts, and stack recommendations delivered every Tuesday. Free." />

      <div class="logo-bar">
        <p class="logo-bar-label">Tracking hiring data from {totalCompanies.toLocaleString()}+ companies including</p>
        <div class="logo-bar-row">
          <img src="/assets/logos/companies/google.png" alt="Google" class="logo-icon" title="Google" />
          <img src="/assets/logos/companies/amazon.png" alt="Amazon" class="logo-icon" title="Amazon" />
          <img src="/assets/logos/companies/meta.png" alt="Meta" class="logo-icon" title="Meta" />
          <img src="/assets/logos/companies/brex.png" alt="Brex" class="logo-icon" title="Brex" />
          <img src="/assets/logos/companies/rippling.png" alt="Rippling" class="logo-icon" title="Rippling" />
          <img src="/assets/logos/companies/adobe.png" alt="Adobe" class="logo-icon" title="Adobe" />
          <img src="/assets/logos/companies/intuit.png" alt="Intuit" class="logo-icon" title="Intuit" />
          <img src="/assets/logos/companies/paypal.png" alt="PayPal" class="logo-icon" title="PayPal" />
          <img src="/assets/logos/companies/twilio.png" alt="Twilio" class="logo-icon" title="Twilio" />
          <img src="/assets/logos/companies/spacex.png" alt="SpaceX" class="logo-icon" title="SpaceX" />
          <img src="/assets/logos/companies/apple.png" alt="Apple" class="logo-icon" title="Apple" />
          <img src="/assets/logos/companies/microsoft.png" alt="Microsoft" class="logo-icon" title="Microsoft" />
        </div>
      </div>

      <div class="testimonials">
        <div class="testimonial-card">
          <p class="testimonial-quote">"We were about to renew ZoomInfo at $40K. Checked DataStackGuide, found three alternatives with better job demand data, and switched to Apollo at a third of the cost."</p>
          <div class="testimonial-author">
            <span class="testimonial-name">Jake R., VP Revenue Ops</span>
            <span class="testimonial-role">Series B SaaS</span>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">"The job demand numbers set this apart. Clay shows up in 26 postings, Clearbit in 4. That tells me more than any G2 review."</p>
          <div class="testimonial-author">
            <span class="testimonial-name">Lauren M., Head of Data</span>
            <span class="testimonial-role">Mid-Market Fintech</span>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">"Every other comparison site ranks by who pays them the most. This one ranks by actual hiring demand. Subscribed after reading one pricing breakdown."</p>
          <div class="testimonial-author">
            <span class="testimonial-name">Derek S., Sales Ops Manager</span>
            <span class="testimonial-role">Enterprise Tech</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2>Browse by Category</h2>
      <div class="category-grid">
        {categories.map((cat: any) => (
          <CategoryCard
            name={cat.name}
            slug={cat.slug}
            description={cat.description}
            toolCount={cat.tool_count}
            color={cat.color}
            icon={cat.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Trending Tools -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Most In-Demand Tools</h2>
        <p class="text-secondary">Based on job posting frequency across {totalCompanies.toLocaleString()}+ companies.</p>
      </div>
      <div class="tool-grid">
        {topTools.slice(0, 12).map((tool: any) => {
          const primaryCat = tool.categories[0];
          return (
            <ToolCard
              name={tool.name}
              slug={tool.slug}
              category={getCategoryName(primaryCat)}
              categorySlug={primaryCat}
              categoryColor={getCategoryColor(primaryCat)}
              jobCount={tool.job_count}
            />
          );
        })}
      </div>
      <div class="section-cta">
        <a href="/tools/" class="btn-outline">View all tools →</a>
      </div>
    </div>
  </section>

  <!-- Explore -->
  <section class="section">
    <div class="container">
      <h2>Explore</h2>
      <div class="explore-grid">
        <a href="/compare/" class="explore-card card">
          <strong>Compare Tools</strong>
          <p>Side-by-side comparisons with real pricing and job demand data.</p>
        </a>
        <a href="/best/" class="explore-card card">
          <strong>Best-Of Roundups</strong>
          <p>Curated picks for every category, use case, and budget.</p>
        </a>
        <a href="/guides/" class="explore-card card">
          <strong>Guides</strong>
          <p>Frameworks for evaluating tools and building tech stacks.</p>
        </a>
        <a href="/glossary/" class="explore-card card">
          <strong>Glossary</strong>
          <p>Clear definitions for B2B data terms without the jargon.</p>
        </a>
        <a href="/use-cases/" class="explore-card card">
          <strong>Use Cases</strong>
          <p>Tool recommendations by role, team size, and workflow.</p>
        </a>
        <a href="/reports/" class="explore-card card">
          <strong>Reports</strong>
          <p>Data-driven analysis of tool adoption and salary trends.</p>
        </a>
        <a href="/pricing/" class="explore-card card">
          <strong>Pricing</strong>
          <p>Published plans, hidden costs, and what you'll actually pay.</p>
        </a>
        <a href="/alternatives/" class="explore-card card">
          <strong>Alternatives</strong>
          <p>Side-by-side alternatives for every major B2B data tool.</p>
        </a>
        <a href="/integrations/" class="explore-card card">
          <strong>Integrations</strong>
          <p>How popular tools work together, based on real job data.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Methodology -->
  <section class="section section-alt">
    <div class="container-narrow">
      <div class="methodology">
        <h2>How we get our data</h2>
        <p>We analyze {totalJobs.toLocaleString()}+ job postings across {totalCompanies.toLocaleString()}+ companies to measure real-world tool adoption. When companies hire for roles that require specific tools, it shows what they're actually using, not what they claim to use.</p>
        <p>Every tool page includes job demand data, salary correlations, and co-occurrence insights you won't find anywhere else. No pay-to-play. No vendor-sponsored rankings.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    background: var(--gradient-brand-deep);
    color: #fff;
    padding: var(--space-16) 0;
    text-align: center;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 640px;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-10);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-number {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--teal-300);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--teal-200);
  }

  .newsletter-hero-section {
    padding: var(--space-10) 0 var(--space-12);
    background: var(--slate-900);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .logo-bar {
    margin-top: var(--space-8);
    text-align: center;
  }

  .logo-bar-label {
    font-size: var(--text-sm);
    color: var(--slate-400);
    margin-bottom: var(--space-4);
  }

  .logo-bar-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    filter: grayscale(100%) brightness(0.7);
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .logo-icon:hover {
    filter: grayscale(0%) brightness(1);
    opacity: 1;
    box-shadow: 0 0 16px rgba(20, 184, 166, 0.3);
  }

  .testimonials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .testimonial-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .testimonial-quote {
    font-size: var(--text-sm);
    color: var(--slate-300);
    line-height: 1.7;
    margin: 0 0 var(--space-4);
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--slate-200);
  }

  .testimonial-role {
    font-size: var(--text-xs);
    color: var(--slate-500);
  }

  .section {
    padding: var(--space-16) 0;
  }

  .section-alt {
    background: var(--color-bg);
  }

  .section h2 {
    margin-bottom: var(--space-8);
  }

  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-header p {
    margin-top: var(--space-2);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .section-cta {
    text-align: center;
    margin-top: var(--space-8);
  }

  .cta-banner {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
  }

  .cta-content h2 {
    margin-bottom: var(--space-3);
  }

  .cta-content p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    max-width: 560px;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .methodology {
    text-align: center;
  }

  .methodology h2 {
    margin-bottom: var(--space-4);
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .explore-card {
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .explore-card:hover {
    border-color: var(--color-primary);
  }

  .explore-card strong {
    display: block;
    margin-bottom: var(--space-1);
  }

  .explore-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .methodology p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-10) 0;
    }

    .hero h1 {
      font-size: var(--text-2xl);
    }

    .hero-stats {
      gap: var(--space-6);
    }

    .cta-buttons {
      flex-direction: column;
    }

    .testimonials {
      grid-template-columns: 1fr;
    }
  }

  /* Newsletter Preview Mockup */
  .dsg-preview-wrapper {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .dsg-preview-heading {
    font-size: var(--text-2xl);
    color: var(--slate-50);
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
  }

  .dsg-preview-subheading {
    font-size: var(--text-base);
    color: var(--slate-400);
    margin-bottom: var(--space-8);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .dsg-preview-window {
    max-width: 640px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(20, 184, 166, 0.2);
    background: linear-gradient(180deg, #0f1a20 0%, #0d1117 100%);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4), 0 0 40px rgba(20, 184, 166, 0.06);
    text-align: left;
  }

  .dsg-preview-toolbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #161b22;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .dsg-preview-dots {
    display: flex;
    gap: 6px;
  }

  .dsg-preview-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dsg-preview-dot--red { background: #ff5f57; }
  .dsg-preview-dot--yellow { background: #febc2e; }
  .dsg-preview-dot--green { background: #28c840; }

  .dsg-preview-toolbar-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--slate-500);
    letter-spacing: 0.02em;
  }

  .dsg-preview-body {
    padding: 24px;
    position: relative;
    overflow: hidden;
  }

  .dsg-preview-header {
    margin-bottom: 20px;
  }

  .dsg-preview-from {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dsg-preview-avatar {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: linear-gradient(135deg, #0d9488, #14b8a6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .dsg-preview-sender {
    display: block;
    font-size: 13px;
    color: var(--slate-200);
    font-weight: 600;
  }

  .dsg-preview-date {
    font-size: 11px;
    color: var(--slate-500);
    font-family: var(--font-mono);
  }

  .dsg-preview-headline {
    font-size: 18px;
    font-weight: 700;
    color: var(--slate-50);
    line-height: 1.35;
    margin: 0 0 20px;
    letter-spacing: -0.01em;
  }

  .dsg-preview-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }

  .dsg-preview-stat-card {
    background: rgba(20, 184, 166, 0.06);
    border: 1px solid rgba(20, 184, 166, 0.15);
    border-radius: 8px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dsg-preview-stat-number {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--teal-400);
    line-height: 1;
  }

  .dsg-preview-stat-label {
    font-size: 11px;
    color: var(--slate-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .dsg-preview-stat-trend {
    font-size: 11px;
    font-family: var(--font-mono);
    margin-top: 2px;
  }

  .dsg-preview-stat-trend--up {
    color: #34d399;
  }

  .dsg-preview-signals {
    display: flex;
    align-items: center;
