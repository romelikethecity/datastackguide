---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ToolCard from '../components/ToolCard.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';

import categoriesData from '../../data/categories.json';
import marketData from '../../data/market_signals.json';

const categories = categoriesData.categories;
const topTools = marketData.top_tools;
const totalJobs = marketData.total_jobs_analyzed;
const totalCompanies = marketData.total_companies;
const totalTools = marketData.total_tools_tracked;

// Find category color for each tool
function getCategoryColor(catSlug: string): string {
  const cat = categories.find((c: any) => c.slug === catSlug);
  return cat?.color || '#14B8A6';
}

function getCategoryName(catSlug: string): string {
  const cat = categories.find((c: any) => c.slug === catSlug);
  return cat?.name || catSlug;
}

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://datastackguide.com/#organization",
      "name": "DataStackGuide",
      "url": "https://datastackguide.com",
      "logo": "https://datastackguide.com/assets/icons/icon.svg",
      "description": "Compare 200+ B2B data enrichment, validation, and intent tools. Real pricing, honest reviews, job market demand data."
    },
    {
      "@type": "WebSite",
      "@id": "https://datastackguide.com/#website",
      "name": "DataStackGuide",
      "url": "https://datastackguide.com",
      "publisher": { "@id": "https://datastackguide.com/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://datastackguide.com/tools/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
};
---

<BaseLayout
  title="Find the Right B2B Data Tool"
  description="Compare 200+ B2B data enrichment, validation, and intent tools. Real pricing, honest reviews, and job demand data from 23,000+ postings."
  canonicalPath=""
  schema={schema}
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Find the Right B2B Data Tool</h1>
      <p class="hero-sub">Compare data enrichment, validation, and intent tools. Real pricing. Honest reviews. Job demand data from {totalJobs.toLocaleString()}+ postings.</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number mono">{totalTools}+</span>
          <span class="stat-label">Tools tracked</span>
        </div>
        <div class="stat">
          <span class="stat-number mono">{totalJobs.toLocaleString()}+</span>
          <span class="stat-label">Jobs analyzed</span>
        </div>
        <div class="stat">
          <span class="stat-number mono">{totalCompanies.toLocaleString()}+</span>
          <span class="stat-label">Companies</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA + Social Proof -->
  <section class="section newsletter-hero-section">
    <div class="container">
      <NewsletterCTA variant="banner" heading="This data changes every week" subtext="Get the latest tool demand trends, pricing shifts, and stack recommendations delivered every Tuesday. Free." />

      <div class="logo-bar">
        <p class="logo-bar-label">Tracking hiring data from {totalCompanies.toLocaleString()}+ companies including</p>
        <div class="logo-bar-row">
          <img src="/assets/logos/companies/google.png" alt="Google" class="logo-icon" title="Google" />
          <img src="/assets/logos/companies/amazon.png" alt="Amazon" class="logo-icon" title="Amazon" />
          <img src="/assets/logos/companies/meta.png" alt="Meta" class="logo-icon" title="Meta" />
          <img src="/assets/logos/companies/brex.png" alt="Brex" class="logo-icon" title="Brex" />
          <img src="/assets/logos/companies/rippling.png" alt="Rippling" class="logo-icon" title="Rippling" />
          <img src="/assets/logos/companies/adobe.png" alt="Adobe" class="logo-icon" title="Adobe" />
          <img src="/assets/logos/companies/intuit.png" alt="Intuit" class="logo-icon" title="Intuit" />
          <img src="/assets/logos/companies/paypal.png" alt="PayPal" class="logo-icon" title="PayPal" />
          <img src="/assets/logos/companies/twilio.png" alt="Twilio" class="logo-icon" title="Twilio" />
          <img src="/assets/logos/companies/spacex.png" alt="SpaceX" class="logo-icon" title="SpaceX" />
          <img src="/assets/logos/companies/apple.png" alt="Apple" class="logo-icon" title="Apple" />
          <img src="/assets/logos/companies/microsoft.png" alt="Microsoft" class="logo-icon" title="Microsoft" />
        </div>
      </div>

      <div class="testimonials">
        <div class="testimonial-card">
          <p class="testimonial-quote">"Saved me hours of vendor research. The job demand data shows what companies actually use, not what vendors claim."</p>
          <div class="testimonial-author">
            <span class="testimonial-name">VP of Revenue Operations</span>
            <span class="testimonial-role">Series B SaaS</span>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">"I used to spend half a day comparing enrichment tools. Now I check DataStackGuide every Tuesday and know exactly what's trending."</p>
          <div class="testimonial-author">
            <span class="testimonial-name">Head of Data</span>
            <span class="testimonial-role">Mid-Market Fintech</span>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">"The pricing breakdowns alone are worth subscribing for. Every other comparison site is pay-to-play."</p>
          <div class="testimonial-author">
            <span class="testimonial-name">Sales Ops Manager</span>
            <span class="testimonial-role">Enterprise Tech</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2>Browse by Category</h2>
      <div class="category-grid">
        {categories.map((cat: any) => (
          <CategoryCard
            name={cat.name}
            slug={cat.slug}
            description={cat.description}
            toolCount={cat.tool_count}
            color={cat.color}
            icon={cat.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Trending Tools -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Most In-Demand Tools</h2>
        <p class="text-secondary">Based on job posting frequency across {totalCompanies.toLocaleString()}+ companies.</p>
      </div>
      <div class="tool-grid">
        {topTools.slice(0, 12).map((tool: any) => {
          const primaryCat = tool.categories[0];
          return (
            <ToolCard
              name={tool.name}
              slug={tool.slug}
              category={getCategoryName(primaryCat)}
              categorySlug={primaryCat}
              categoryColor={getCategoryColor(primaryCat)}
              jobCount={tool.job_count}
            />
          );
        })}
      </div>
      <div class="section-cta">
        <a href="/tools/" class="btn-outline">View all tools →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <div class="cta-content">
          <h2>Don't have time to manage this yourself?</h2>
          <p>Verum handles data cleaning and enrichment as a service. Projects start at $500, delivered in 24-48 hours.</p>
          <div class="cta-buttons">
            <a href="https://veruminc.com" class="btn" target="_blank" rel="noopener">Learn about Verum →</a>
            <a href="https://getprovyx.com" class="btn-outline" target="_blank" rel="noopener">Healthcare data? Try Provyx →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Explore -->
  <section class="section">
    <div class="container">
      <h2>Explore</h2>
      <div class="explore-grid">
        <a href="/compare/" class="explore-card card">
          <strong>Compare Tools</strong>
          <p>Side-by-side comparisons with real pricing and job demand data.</p>
        </a>
        <a href="/best/" class="explore-card card">
          <strong>Best-Of Roundups</strong>
          <p>Curated picks for every category, use case, and budget.</p>
        </a>
        <a href="/guides/" class="explore-card card">
          <strong>Guides</strong>
          <p>Frameworks for evaluating tools and building tech stacks.</p>
        </a>
        <a href="/glossary/" class="explore-card card">
          <strong>Glossary</strong>
          <p>Clear definitions for B2B data terms without the jargon.</p>
        </a>
        <a href="/use-cases/" class="explore-card card">
          <strong>Use Cases</strong>
          <p>Tool recommendations by role, team size, and workflow.</p>
        </a>
        <a href="/reports/" class="explore-card card">
          <strong>Reports</strong>
          <p>Data-driven analysis of tool adoption and salary trends.</p>
        </a>
        <a href="/pricing/" class="explore-card card">
          <strong>Pricing</strong>
          <p>Published plans, hidden costs, and what you'll actually pay.</p>
        </a>
        <a href="/alternatives/" class="explore-card card">
          <strong>Alternatives</strong>
          <p>Side-by-side alternatives for every major B2B data tool.</p>
        </a>
        <a href="/integrations/" class="explore-card card">
          <strong>Integrations</strong>
          <p>How popular tools work together, based on real job data.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Methodology -->
  <section class="section section-alt">
    <div class="container-narrow">
      <div class="methodology">
        <h2>How we get our data</h2>
        <p>We analyze {totalJobs.toLocaleString()}+ job postings across {totalCompanies.toLocaleString()}+ companies to measure real-world tool adoption. When companies hire for roles that require specific tools, it shows what they're actually using, not what they claim to use.</p>
        <p>Every tool page includes job demand data, salary correlations, and co-occurrence insights you won't find anywhere else. No pay-to-play. No vendor-sponsored rankings.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    background: var(--gradient-brand-deep);
    color: #fff;
    padding: var(--space-16) 0;
    text-align: center;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 640px;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-10);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-number {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--teal-300);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--teal-200);
  }

  .newsletter-hero-section {
    padding: var(--space-10) 0 var(--space-12);
    background: var(--slate-900);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .logo-bar {
    margin-top: var(--space-8);
    text-align: center;
  }

  .logo-bar-label {
    font-size: var(--text-sm);
    color: var(--slate-400);
    margin-bottom: var(--space-4);
  }

  .logo-bar-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    filter: grayscale(100%) brightness(0.7);
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .logo-icon:hover {
    filter: grayscale(0%) brightness(1);
    opacity: 1;
    box-shadow: 0 0 16px rgba(20, 184, 166, 0.3);
  }

  .testimonials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .testimonial-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .testimonial-quote {
    font-size: var(--text-sm);
    color: var(--slate-300);
    line-height: 1.7;
    margin: 0 0 var(--space-4);
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--slate-200);
  }

  .testimonial-role {
    font-size: var(--text-xs);
    color: var(--slate-500);
  }

  .section {
    padding: var(--space-16) 0;
  }

  .section-alt {
    background: var(--color-bg);
  }

  .section h2 {
    margin-bottom: var(--space-8);
  }

  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-header p {
    margin-top: var(--space-2);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .section-cta {
    text-align: center;
    margin-top: var(--space-8);
  }

  .cta-banner {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
  }

  .cta-content h2 {
    margin-bottom: var(--space-3);
  }

  .cta-content p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    max-width: 560px;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .methodology {
    text-align: center;
  }

  .methodology h2 {
    margin-bottom: var(--space-4);
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .explore-card {
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .explore-card:hover {
    border-color: var(--color-primary);
  }

  .explore-card strong {
    display: block;
    margin-bottom: var(--space-1);
  }

  .explore-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .methodology p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-10) 0;
    }

    .hero h1 {
      font-size: var(--text-2xl);
    }

    .hero-stats {
      gap: var(--space-6);
    }

    .cta-buttons {
      flex-direction: column;
    }

    .testimonials {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-stats {
      flex-direction: column;
      gap: var(--space-4);
    }

    .logo-bar-row {
      gap: var(--space-3);
    }

    .logo-icon {
      width: 32px;
      height: 32px;
    }
  }
</style>
